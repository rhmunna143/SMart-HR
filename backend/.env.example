# ─── Database ────────────────────────────────────────────────────────────────
# Neon: Settings → Connection string → Pooled connection
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── JWT Secrets ─────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-random-64-hex-chars-string
JWT_REFRESH_SECRET=replace-with-a-different-random-64-hex-chars-string

# ─── Token TTLs (optional – defaults shown) ──────────────────────────────────
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
# Local dev: http://localhost:3000
# Production: your Vercel frontend URL, e.g. https://smart-hr-web.vercel.app
CORS_ORIGIN=http://localhost:3000

# ─── Server (optional) ───────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Attachments (optional – default 5 MB) ───────────────────────────────────
MAX_ATTACHMENT_BYTES=5242880
